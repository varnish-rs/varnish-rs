varnishtest "echo backend forwards bereq body via Ctx::req_body/req_body_state - happy path"

server s1 {} -start

varnish v1 -vcl+backend {
    import std;
    import echo_backend from "${vmod}";

    sub vcl_init {
        new echo = echo_backend.new();
    }

    sub vcl_recv {
        if (req.http.x-cache-body == "1") {
            std.cache_req_body(1MB);
        }
        set req.backend_hint = echo.backend();
        return (pass);
    }
} -start

# streamed body: read live from the client via VRB_Iterate
client c1 {
    txreq -method "POST" -body "hello world"
    rxresp
    expect resp.status == 200
    expect resp.http.x-had-body == "1"
    expect resp.http.x-body-state == "Length"
    expect resp.body == "hello world"
} -run

# cached body: std.cache_req_body() forces bo.bereq_body, read via ObjIterate
client c2 {
    txreq -method "POST" -hdr "x-cache-body: 1" -body "cached body"
    rxresp
    expect resp.status == 200
    expect resp.http.x-had-body == "1"
    expect resp.http.x-body-state == "Cached"
    expect resp.body == "cached body"
} -run

# no body at all: req_body() must return Ok(false) without touching the writer
client c3 {
    txreq -method "GET"
    rxresp
    expect resp.status == 200
    expect resp.http.x-had-body == "0"
    expect resp.http.x-body-state == "None"
    expect resp.bodylen == 0
} -run

# large streamed body: exercises multiple write_all() calls across VRB_Iterate chunks.
# One-time check with a since-removed counting Write wrapper confirmed 512KiB
# arrived as 33 separate write() calls; this test itself only proves the body
# round-trips correctly, not the chunk count (nothing here re-verifies that on
# every run).
client c4 {
    txreq -method "POST" -bodylen 524288
    rxresp
    expect resp.status == 200
    expect resp.http.x-had-body == "1"
    expect resp.http.x-body-state == "Length"
    expect resp.bodylen == 524288
} -run

# client declares a body longer than what it actually sends, then stops (half-close):
# VRB_Iterate must see this as a short read (BS_ERROR), req_body() must
# return Err, and the fetch must fail instead of hanging or panicking. Pin this
# to the actual Varnish-side failure, not just the resulting 400, so a future
# change that produces 400 for an unrelated reason doesn't pass silently.
logexpect l1 -v v1 -g raw {
    expect * * FetchError "straight insufficient bytes"
} -start

client c5 {
    txreq -method "POST" -hdr "Content-Length: 100"
    send "too short"
    shutdown -write
    rxresp
    expect resp.status == 400
} -run

logexpect l1 -wait

# chunked transfer encoding (BS_CHUNKED, length unknown upfront): exercises the
# BodyState::Chunked branch, which none of the other clients touch (they only
# ever produce Length/Cached/None)
client c6 {
    txreq -method "POST" -nolen -hdr "Transfer-encoding: chunked"
    chunked {hello }
    chunkedlen 5
    chunkedlen 0
    rxresp
    expect resp.status == 200
    expect resp.http.x-had-body == "1"
    expect resp.http.x-body-state == "Chunked"
    expect resp.bodylen == 11
} -run

# the C side reads the whole body successfully, but the *writer* fails partway:
# req_body() must propagate the writer's own io::Error (status 503, generic
# backend-fetch-failure) rather than the streamed-read-error path's 400 (c5).
# req_body() explicitly skips the C-side BS_ERROR bookkeeping whenever the
# failure was writer-caused, keeping these two error paths distinct
client c7 {
    txreq -method "POST" -hdr "x-fail-after-bytes: 3" -body "hello world"
    rxresp
    expect resp.status == 503
} -run

# same writer-error path as c7, but with a body large enough to span multiple
# VRB_Iterate/write_all() chunks (c4 confirmed 512KiB arrives over many calls).
# Without the `state.error.is_none()` guard in req_body's streamed branch,
# a writer failure on a non-final chunk also leaves the C side's
# req_body_status as BS_ERROR (mirrors vrb_pull), which used to get
# misattributed as the c5 short-read case (400) instead of surfacing as this
# writer's own error (503)
client c8 {
    txreq -method "POST" -hdr "x-fail-after-bytes: 3" -bodylen 524288
    rxresp
    expect resp.status == 503
} -run
