varnishtest "testing .hello()"

server s1 {
    rxreq
    expect req.http.greeting == "Hello, world"
    txresp
} -start

varnish v1 -vcl+backend {
    import example from "${vmod}";

    sub vcl_recv {
        set req.http.greeting = example.hello(req.http.name);
    }
} -start

client c1 {
    txreq -hdr "name: world"
    rxresp
    expect resp.status == 200

    txreq -hdr "name: "
    rxresp
    expect resp.status == 503
} -run
