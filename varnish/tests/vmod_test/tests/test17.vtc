varnishtest "req_body_as_string() called from every vcl_* subroutine must not crash - cached body"

# mirrors test16.vtc (same 13 routines, same client/server structure), but
# vcl_recv calls std.cache_req_body() unconditionally first, so the backend
# side reads bereq's body as a cached object (ObjIterate) instead of
# streaming it live from the client (VRB_Iterate) - see the body_status_debug
# assertions on c11/c12/c13 below for where that actually changes anything.

# exactly 5 of the 13 client requests below actually reach a real backend
# connection - every other routine's call fails (or, for backend_error,
# forces return(error(500))) before any fetch/connect is dispatched. These 5
# pairs are matched in client-execution order, so reordering the client
# blocks below (or changing which routine short-circuits before/after a
# fetch) desyncs this list - a mismatch shows up as a hang/timeout here, not
# a clean assertion failure, so keep the -url expectation on each rxreq.
server s1 {
    # c7: cache-priming GET
    rxreq
    expect req.url == "/hit"
    txresp

    # c10: routine=deliver
    rxreq
    expect req.url == "/deliver"
    txresp

    # c11: routine=backend_fetch
    rxreq
    expect req.url == "/backend_fetch"
    txresp

    # c12: routine=backend_response
    rxreq
    expect req.url == "/backend_response"
    txresp

    # c5: routine=pipe (run last, closes the connection)
    rxreq
    expect req.url == "/pipe"
    txresp
} -start

varnish v1 -vcl+backend {
    import std;
    import rustest from "${vmod}";

    sub vcl_recv {
        std.cache_req_body(1MB);

        if (req.http.routine == "recv") {
            set req.http.body_string = rustest.req_body_as_string();
        }
        if (req.http.routine == "synth") {
            return (synth(200));
        }
        if (req.http.routine == "pipe") {
            return (pipe);
        }
        if (req.http.routine == "pass") {
            return (pass);
        }
        if (req.http.routine == "purge") {
            return (purge);
        }
        return (hash);
    }

    sub vcl_hash {
        if (req.http.routine == "hash") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_purge {
        if (req.http.routine == "purge") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_pipe {
        if (req.http.routine == "pipe") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_pass {
        if (req.http.routine == "pass") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_hit {
        if (req.http.routine == "hit") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_miss {
        if (req.http.routine == "miss") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_deliver {
        if (req.http.routine == "deliver") {
            set req.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_synth {
        if (req.http.routine == "synth") {
            set resp.http.body_string = rustest.req_body_as_string();
        } else {
            set resp.http.body_string = req.http.body_string;
        }
    }

    sub vcl_backend_fetch {
        if (bereq.http.routine == "backend_fetch") {
            set bereq.http.x-result = rustest.req_body_as_string();
            set bereq.http.x-status = rustest.req_body_status_as_string();
        }
        if (bereq.http.routine == "backend_error") {
            return (error(500));
        }
    }

    sub vcl_backend_response {
        if (bereq.http.routine == "backend_fetch") {
            set beresp.http.body_string = bereq.http.x-result;
            set beresp.http.body_status_debug = bereq.http.x-status;
        }
        if (bereq.http.routine == "backend_response") {
            set beresp.http.body_status_debug = rustest.req_body_status_as_string();
            set beresp.http.body_string = rustest.req_body_as_string();
        }
    }

    sub vcl_backend_error {
        if (bereq.http.routine == "backend_error") {
            set beresp.http.body_status_debug = rustest.req_body_status_as_string();
            set beresp.http.body_string = rustest.req_body_as_string();
        }
    }
} -start

# each of these fails gracefully (bo is null client-side), confirming the call
# doesn't crash - it just fails the VCL task, same as any other Result-returning
# vmod function would. std.cache_req_body() only affects the backend-side view
# of the body, so these client-context outcomes are identical to the streamed
# variant (test16.vtc).
client c1 {
    txreq -url "/recv" -hdr "routine: recv" -body "hello recv"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c2 {
    txreq -url "/hash" -hdr "routine: hash" -body "hello hash"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c3 {
    txreq -url "/pass" -hdr "routine: pass" -body "hello pass"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c4 {
    txreq -req "PURGE" -url "/purge" -hdr "routine: purge" -body "hello purge"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c6 {
    txreq -url "/synth" -hdr "routine: synth" -body "hello synth"
    rxresp
    expect resp.status == 500
} -run

# prime the cache for the /hit URL, then hit it
client c7 {
    txreq -url "/hit"
    rxresp
    expect resp.status == 200
} -run

client c8 {
    txreq -url "/hit" -hdr "routine: hit"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c9 {
    txreq -url "/miss" -hdr "routine: miss" -body "hello miss"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

client c10 {
    txreq -url "/deliver" -hdr "routine: deliver" -body "hello deliver"
    rxresp
    expect resp.status == 503
    expect resp.http.body_string == ""
} -run

# backend context: bereq's body is now the cached object (BodyStatus::Cached),
# read via ObjIterate instead of VRB_Iterate.
client c11 {
    txreq -url "/backend_fetch" -hdr "routine: backend_fetch" -body "hello backend fetch"
    rxresp
    expect resp.status == 200
    expect resp.http.body_status_debug == "Ok(Cached)"
    expect resp.http.body_string == "hello backend fetch"
} -run


# unlike vcl_backend_fetch, by the time vcl_backend_response runs, the plain
# default backend has already forwarded bereq's body (cached or not) to the
# real upstream and dropped its reference - req_body_status() reports None
# here regardless of whether the body was cached (same outcome as the
# streamed variant's test16.vtc c12).
client c12 {
    txreq -url "/backend_response" -hdr "routine: backend_response" -body "hello backend response"
    rxresp
    expect resp.status == 200
    expect resp.http.body_status_debug == "Ok(None)"
    expect resp.http.body_string == ""
} -run

client c13 {
    txreq -url "/backend_error" -hdr "routine: backend_error" -body "hello backend error"
    rxresp
    expect resp.status == 500
    expect resp.http.body_status_debug == "Ok(Cached)"
    expect resp.http.body_string == "hello backend error"
} -run

# pipe is special: unlike every other client-side sub, Varnish passes a
# non-null bo into vcl_pipe (see cnt_pipe's VCL_pipe_method(..., bo, ...) in
# cache_req_fsm.c) - but bo.req/bo.bereq_body are both still unset at that
# point (bo.req is only assigned after vcl_pipe returns, and bo.bereq_body
# stays unset here even with std.cache_req_body() called earlier, verified
# empirically), so the call doesn't fail at all: req_body_status() sees
# BodyStatus::None and req_body_read() returns Ok(false)/"" cleanly, same as
# calling it with no body anywhere else. Run last: piping closes the backend
# connection (TX_PIPE), so it can't be followed by another rxreq on the same
# pooled connection.
client c5 {
    txreq -url "/pipe" -hdr "routine: pipe" -body "hello pipe"
    rxresp
    # 200 on this repo's tested Varnish versions (verified: bo.req/bo.bereq_body
    # are still unset at this point, so the call succeeds with an empty body -
    # see the comment above); 503 would mean the call failed instead (bo state
    # differs on some other version). Either is a graceful, non-crashing
    # outcome - that's the actual thing under test here, not one exact status.
    expect resp.status ~ "^(200|503)$"
} -run
