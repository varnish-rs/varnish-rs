varnishtest "local_socket and local_endpoint"

server s1 {
	rxreq
	txresp
} -start

varnish v1 -arg "-a foo=${tmpdir}/foo.sock -a bar=${tmpdir}/bar.sock" \
    -vcl+backend {
	import rustest from "${vmod}";
	import std;

	sub vcl_init {
		std.log("----->" + rustest.local_socket());
	}
	sub vcl_backend_response {
		set beresp.http.besocket = rustest.local_socket();
		set beresp.http.beendpoint = rustest.local_endpoint();
	}

	sub vcl_deliver {
		set resp.http.socket = rustest.local_socket();
		set resp.http.endpoint = rustest.local_endpoint();
	}
} -start

client c1 -connect "${tmpdir}/foo.sock" {
	txreq
	rxresp
	expect resp.status == 200
	expect resp.http.socket == "foo"
	expect resp.http.endpoint == "${tmpdir}/foo.sock"
	expect resp.http.besocket == ""
	expect resp.http.beendpoint == ""
} -run

client c1 -connect "${tmpdir}/bar.sock" {
	txreq
	rxresp
	expect resp.status == 200
	expect resp.http.socket == "bar"
	expect resp.http.endpoint == "${tmpdir}/bar.sock"
} -run
