varnishtest "hash_ignore_busy getter and setter"

server s1 {
    rxreq
    txresp
} -start

varnish v1 -vcl+backend {
    import rustest from "${vmod}";

    sub vcl_recv {
        # default is false
        set req.http.before = rustest.hash_ignore_busy();
        rustest.set_hash_ignore_busy(true);
        set req.http.after = rustest.hash_ignore_busy();
    }

    sub vcl_deliver {
        set resp.http.before = req.http.before;
        set resp.http.after = req.http.after;
    }
} -start

client c1 {
    txreq
    rxresp
    expect resp.status == 200
    expect resp.http.before == "false"
    expect resp.http.after == "true"
} -run
